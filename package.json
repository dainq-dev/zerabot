{
  "name": "zerobot-chan",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "bash scripts/dev.sh",
    "dev:all": "bash scripts/dev.sh",
    "prod:all": "bash scripts/prod.sh",
    "dev:web": "bun run --filter web-control dev",
    "dev:api": "bun run --filter api-bridge dev",
    "build": "bun run --filter '*' build",
    "lint": "bun run --filter '*' lint",
    "clean": "find . -name 'node_modules' -type d -prune -exec rm -rf '{}' + && find . -name '.next' -type d -prune -exec rm -rf '{}' +",
    "test:e2e": "playwright test --project=ui --config=e2e/playwright.config.ts",
    "test:e2e:ui": "playwright test --project=ui --config=e2e/playwright.config.ts --ui",
    "test:integration": "playwright test --project=integration --config=e2e/playwright.config.ts",
    "test:all": "playwright test --config=e2e/playwright.config.ts",
    "test:report": "playwright show-report e2e/results/html"
  },
  "devDependencies": {
    "@playwright/test": "^1.50.0",
    "typescript": "^5.7.3"
  }
}
