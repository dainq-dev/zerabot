# OpenClaw Gateway
OPENCLAW_HOME=~/.openclaw
OPENCLAW_PORT=18789
# Change these from defaults before exposing gateway to network
OPENCLAW_ADMIN_USER=admin
OPENCLAW_ADMIN_PASS=admin123

# Anthropic
ANTHROPIC_API_KEY=sk-ant-...

# OpenAI (optional)
OPENAI_API_KEY=sk-open...

# Brave Search (optional — OpenClaw can search via browser without API key)
# BRAVE_API_KEY=

# Channels (optional)
TELEGRAM_BOT_TOKEN=
DISCORD_BOT_TOKEN=
SLACK_BOT_TOKEN=
SLACK_SIGNING_SECRET=
MATTERMOST_TOKEN=

# API Bridge
API_BRIDGE_PORT=3001
API_BRIDGE_DB_PATH=~/.zerabot/bridge.db
ZERABOT_CONFIG_PATH=./config/zerabot.toml

# Web Control
NEXT_PUBLIC_API_URL=http://localhost:3001
NEXT_PUBLIC_WS_URL=ws://localhost:3001
